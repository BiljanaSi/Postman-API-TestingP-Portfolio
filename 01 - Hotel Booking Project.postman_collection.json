{
  "info": {
    "_postman_id": "01226804-956d-4186-b568-d71d2ef7dbf8",
    "name": "01 - Hotel Booking Project",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "2633273"
  },
  "item": [
    {
      "name": "Create Booking",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200 - Success\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response time is less than 800ms\", function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(800);",
              "});",
              "",
              "var jsonData = pm.response.json();",
              "",
              "pm.test(\"Check if the first name is correct\", function () {",
              "    pm.expect(jsonData.booking.firstname).to.eql(\"Petar\");",
              "});",
              "",
              "pm.test(\"Check if the last name is correct\", function () {",
              "    pm.expect(jsonData.booking.lastname).to.eql(\"Petrovic\");",
              "});",
              "",
              "pm.test(\"Booking ID is present and saved\", function () {",
              "    pm.expect(jsonData.bookingid).to.be.a('number');",
              "    pm.environment.set(\"bookingId\", jsonData.bookingid);",
              "});",
              "",
              "pm.test(\"Booking dates are present in the response\", function () {",
              "    pm.expect(jsonData.booking.bookingdates).to.have.property('checkin');",
              "    pm.expect(jsonData.booking.bookingdates).to.have.property('checkout');",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"firstname\" : \"Petar\",\n    \"lastname\" : \"Petrovic\",\n    \"totalprice\" : 120,\n    \"depositpaid\" : true,\n    \"bookingdates\" : {\n        \"checkin\" : \"2024-05-01\",\n        \"checkout\" : \"2024-05-10\"\n    },\n    \"additionalneeds\" : \"Breakfast\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{url}}/booking",
          "host": [
            "{{url}}"
          ],
          "path": [
            "booking"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Get Booking Details",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response time is less than 500ms\", function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(500);",
              "});",
              "",
              "var jsonData = pm.response.json();",
              "",
              "pm.test(\"Verify user data integrity\", function () {",
              "    pm.expect(jsonData.firstname).to.eql(\"Petar\");",
              "    pm.expect(jsonData.lastname).to.eql(\"Petrovic\");",
              "    pm.expect(jsonData.totalprice).to.be.a('number'); ",
              "    pm.expect(jsonData.depositpaid).to.be.true;",
              "});",
              "",
              "pm.test(\"Verify booking dates structure\", function () {",
              "    pm.expect(jsonData.bookingdates.checkin).to.not.be.null;",
              "    pm.expect(jsonData.bookingdates.checkout).to.not.be.null;",
              "});",
              "",
              "pm.test(\"Content-Type is application/json\", function () {",
              "    pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\");",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "protocolProfileBehavior": {
        "disableBodyPruning": true
      },
      "request": {
        "auth": {
          "type": "noauth"
        },
        "method": "GET",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"firstname\" : \"Petar\",\n    \"lastname\" : \"Petrovic\",\n    \"totalprice\" : 120,\n    \"depositpaid\" : true,\n    \"bookingdates\" : {\n        \"checkin\" : \"2024-05-01\",\n        \"checkout\" : \"2024-05-10\"\n    },\n    \"additionalneeds\" : \"Breakfast\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{url}}/booking/{{bookingId}}",
          "host": [
            "{{url}}"
          ],
          "path": [
            "booking",
            "{{bookingId}}"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Create Auth Token",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200 - Login Successful\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "var jsonData = pm.response.json();",
              "",
              "pm.test(\"Token is present in response\", function () {",
              "    pm.expect(jsonData.token).to.be.a('string');",
              "    ",
              "    pm.environment.set(\"token\", jsonData.token);",
              "    console.log(\"Token generated: \" + jsonData.token);",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"username\" : \"admin\",\n    \"password\" : \"password123\"\n}\n",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{url}}/auth",
          "host": [
            "{{url}}"
          ],
          "path": [
            "auth"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Delete Booking",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201 - Deleted successfully\", function () {",
              "    pm.response.to.have.status(201); // ",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Cookie",
            "value": "token={{token}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{url}}/booking/{{bookingId}}",
          "host": [
            "{{url}}"
          ],
          "path": [
            "booking",
            "{{bookingId}}"
          ]
        }
      },
      "response": []
    }
  ]
